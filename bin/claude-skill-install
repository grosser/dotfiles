#!/usr/bin/env ruby
# install a skill into ~/.claude/skills with local modifications
# and keep a record of where it came from for later refreshes
#
# usage:
#   claude-skill-install <folder>   install a single skill from a local folder
#   claude-skill-install <url>      download a skill from a url and install it
#   claude-skill-install --refresh  re-install every previously copied skill
#
# <url>:
#  - a raw SKILL.md url
#  - a github tree url pointing at a skill folder, e.g. https://github.com/owner/repo/tree/main/path/to/skill
#
# <folder>:
#  - symlinked if the ~/.claude-skill-install.yml would mutate
#  - copied otherwise
#
# ~/.claude-skill-install.yml and <SKILL>/.claude-skill-install.yml, supply changes, gsubs, source, etc

require "fileutils"
require "json"
require "shellwords"
require "tmpdir"
require "yaml"

class ClaudeSkillInstall
  DEST = File.expand_path("~/.claude/skills")
  MARKER = "claude-skill-install.yml"
  GLOBAL_MARKER = File.expand_path("~/.claude-skill-install.yml")

  def initialize
    abort "destination dir does not exist: #{DEST}" unless File.directory?(DEST)
    @pulled = []
  end

  def install_from_folder(folder)
    src_abs = File.realpath(File.expand_path(folder))
    abort "not a directory: #{src_abs}" unless File.directory?(src_abs)
    skill_md = File.join(src_abs, "SKILL.md")
    abort "missing SKILL.md in #{src_abs}" unless File.file?(skill_md)

    name = skill_name(src_abs)
    dst = File.join(DEST, name)
    check_dst!(dst)

    marker = { "source" => src_abs }
    unless would_change?(read_frontmatter(skill_md), marker)
      symlink(src_abs, dst, name)
      return
    end

    print "#{name} would be modified by changes/gsubs. [c]opy with changes, [l]ink as-is (ignore changes), [a]bort? "
    case $stdin.gets&.strip&.downcase
    when "c", "copy"
      replace_folder(dst, marker)
      puts "copied #{name} from #{src_abs}"
    when "l", "link"
      symlink(src_abs, dst, name)
    else
      abort "aborted"
    end
  end

  def install_from_url(url)
    marker = { "source" => url }
    Dir.mktmpdir do |tmp|
      staging = File.join(tmp, "skill")
      write_skill_from_url(staging, marker)
      name = skill_name(staging)
      dst = File.join(DEST, name)
      check_dst!(dst)
      FileUtils.cp_r(staging, dst)
      puts "downloaded #{name} from #{url}"
    end
  end

  def refresh
    Dir.children(DEST).sort.each do |name|
      dst = File.join(DEST, name)

      # symlink
      if File.symlink?(dst)
        if File.exist?(dst)
          git_pull_if_on_default(File.realpath(dst))
        else
          warn "broken symlink: #{dst} -> #{File.readlink(dst)}"
        end
        next
      end

      # unmanaged
      next unless (marker = read_marker(dst))

      # copied
      source = marker["source"]
      git_pull_if_on_default(source) if source && !url?(source) && File.directory?(source)
      replace_folder(dst, marker)
      puts "refreshed #{name} from #{marker["source"]}"
    end
  end

  private

  # install helpers

  def check_dst!(dst)
    # refuse so we never parses a marker we didn't write
    abort "refused: #{dst} already has #{MARKER}" if File.file?(File.join(dst, MARKER))

    # user should delete if they want to replace, maybe later add a "do you want to replace" or a --force
    abort "conflict: #{dst} already exists" if File.exist?(dst)
  end

  def symlink(src_abs, dst, name)
    File.symlink(src_abs, dst)
    puts "linked #{name} -> #{src_abs}"
  end

  def replace_folder(dst, marker)
    source = marker["source"] || abort("marker missing source")

    if !url?(source) && !File.directory?(source)
      warn "skipped #{dst}: source #{source.inspect} is missing"
      return
    end

    staging = "#{dst}.new"
    FileUtils.rm_rf(staging)
    if url?(source)
      write_skill_from_url(staging, marker)
    else
      write_skill_from_folder(staging, marker)
    end

    git_diff(dst, staging) if File.exist?(dst)

    FileUtils.rm_rf(dst)
    FileUtils.mv(staging, dst)
  end

  def write_skill_from_url(dst, marker)
    source = marker["source"]
    if (parts = github_tree_parts(source))
      download_github_tree(dst, *parts)
      skill = File.read(File.join(dst, "SKILL.md"))
      write_skill_and_marker(dst, marker, *parse_skill(skill))
    else
      write_skill_and_marker(dst, marker, *parse_skill(download(source)))
    end
  end

  def write_skill_from_folder(dst, marker)
    FileUtils.cp_r(marker["source"], dst)
    skill = File.read(File.join(dst, "SKILL.md"))
    write_skill_and_marker(dst, marker, *parse_skill(skill))
  end

  def write_skill_and_marker(dst, marker, fm, body)
    FileUtils.mkdir_p(dst)

    # write skill
    effective_marker = global_marker.merge(marker)
    fm = fm.merge(effective_marker["changes"] || {})
    File.write(
      File.join(dst, "SKILL.md"),
      apply_gsubs(render_skill(fm, body), effective_marker["gsubs"])
    )

    # write marker so we can --refresh
    write_marker(dst, marker)
  end

  # skill parsing

  def skill_name(dir)
    read_frontmatter(File.join(dir, "SKILL.md"))["name"] || File.basename(dir)
  end

  def read_frontmatter(path)
    parse_skill(File.read(path)).first
  end

  def parse_skill(content)
    abort "missing frontmatter" unless content.start_with?("---\n")
    _, fm, body = content.split(/^---\s*$\n/, 3)
    [YAML.safe_load(fm || "") || {}, body.to_s]
  end

  def render_skill(fm, body)
    "---\n#{fm.to_yaml.sub(/\A---\n/, "")}---\n#{body}"
  end

  def apply_gsubs(content, gsubs)
    return content if gsubs.nil? || gsubs.empty?
    gsubs.each { |search, replace| content = content.gsub(search, replace) }
    content
  end

  # TODO: if the default value is set via changes this always says it would change -> hardcode claude defaults
  # TODO: gsubs might do nothing and it will still say there are changes -> pass the whole skill and test
  def would_change?(fm, marker)
    effective = global_marker.merge(marker)
    changes = effective["changes"] || {}
    gsubs = effective["gsubs"] || []
    gsubs.any? || changes.any? { |k, v| fm[k] != v }
  end

  # marker

  def read_marker(dst)
    path = File.join(dst, MARKER)
    return unless File.file?(path)
    YAML.safe_load(File.read(path), filename: path)
  end

  def write_marker(dst, marker)
    source = marker["source"] || abort("spec missing source")
    ref = git_ref(source) unless url?(source)
    marker["git_ref"] = ref if ref
    File.write(File.join(dst, MARKER), marker.to_yaml)
  end

  def global_marker
    return {} unless File.file?(GLOBAL_MARKER)
    YAML.safe_load(File.read(GLOBAL_MARKER), filename: GLOBAL_MARKER) || {}
  end

  # git

  def git_diff(old, new)
    system("git", "diff", "--no-index", "--color=auto", old, new)
  end

  def git_pull_if_on_default(source)
    return unless (top = git_toplevel(source))
    return if @pulled.include?(top)
    @pulled << top
    branch = git_branch(top)
    return unless ["main", "master"].include?(branch)
    out = `git -C #{top.shellescape} pull --ff-only 2>&1`
    if $?.success?
      puts "pulled #{top} (#{branch})"
    else
      warn "git pull failed for #{top}, continuing with current state:\n#{out.strip}"
    end
  end

  def git_toplevel(dir)
    top = `git -C #{dir.shellescape} rev-parse --show-toplevel 2>/dev/null`.strip
    top.empty? ? nil : top
  end

  def git_branch(dir)
    branch = `git -C #{dir.shellescape} rev-parse --abbrev-ref HEAD 2>/dev/null`.strip
    branch.empty? ? nil : branch
  end

  def git_ref(dir)
    ref = `git -C #{dir.shellescape} rev-parse HEAD 2>/dev/null`.strip
    ref.empty? ? nil : ref
  end

  # github

  # https://github.com/<owner>/<repo>/tree/<ref>/<path...> -> [owner, repo, ref, *path]
  def github_tree_parts(url)
    _, _, host, owner, repo, tree, ref, *rest = url.split("/")
    return unless host == "github.com" && tree == "tree" && owner && repo && ref && !rest.empty?
    [owner, repo, ref, *rest]
  end

  def download_github_tree(dst, owner, repo, ref, *path_parts)
    FileUtils.mkdir_p(dst)
    download_github_dir(owner, repo, ref, path_parts.join("/"), dst)
  end

  def download_github_dir(owner, repo, ref, path, dst)
    api = "https://api.github.com/repos/#{owner}/#{repo}/contents/#{path}?ref=#{ref}"
    entries = JSON.parse(download(api))
    entries.each do |entry|
      name = entry["name"]
      target = File.join(dst, name)
      case entry["type"]
      when "file"
        File.write(target, download(entry["download_url"]))
      when "dir"
        FileUtils.mkdir_p(target)
        download_github_dir(owner, repo, ref, "#{path}/#{name}", target)
      else
        warn "skipping #{entry["type"]}: #{entry["path"]}"
      end
    end
  end

  # misc

  def url?(s)
    s.start_with?("http://", "https://")
  end

  def download(url)
    cmd = ["curl", "--fail", "--silent", "--show-error", "--location"]
    if (token = ENV["GH_TOKEN"]) && url.match?(%r{\Ahttps://(api\.github\.com|github\.com|raw\.githubusercontent\.com)/})
      cmd += ["--header", "Authorization: Bearer #{token}"]
    end
    out = IO.popen(cmd + [url], &:read)
    abort "download failed: #{url}" unless $?.success?
    out
  end
end

installer = ClaudeSkillInstall.new

if ARGV.delete("--refresh")
  abort "unexpected arguments: #{ARGV.join(" ")}" unless ARGV.empty?
  installer.refresh
else
  arg = ARGV.shift || abort("usage: claude-skill-install <folder-or-url> | --refresh")
  abort "unexpected arguments: #{ARGV.join(" ")}" unless ARGV.empty?
  if arg.start_with?("http://", "https://")
    installer.install_from_url(arg)
  else
    installer.install_from_folder(arg)
  end
end
