#!/usr/bin/env ruby
# install a skill into ~/.claude/skills
#
# usage:
#   claude-skill-install <folder>   install a single skill from a local folder
#   claude-skill-install <url>      download a raw SKILL.md URL and install it
#   claude-skill-install --refresh  re-install every previously copied skill
#
# urls must be raw http(s) urls pointing at a SKILL.md (e.g. a github raw url).
# the skill folder name is taken from the last path segment of the url. if the
# downloaded SKILL.md already has `disable-model-invocation: true`, local
# folders are symlinked. otherwise you are asked whether to link/keep as-is or
# copy with invocation disabled. url-sourced skills are always copied.
# copied skills get a claude-skill-install.yml marker so --refresh can re-pull
# them from their source.

require "fileutils"
require "shellwords"
require "yaml"

DEST = File.expand_path("~/.claude/skills")
MARKER = "claude-skill-install.yml"

def url?(s)
  s.start_with?("http://", "https://")
end

def parse_frontmatter(path)
  content = File.read(path)
  abort "missing frontmatter in #{path}" unless content.start_with?("---\n")
  _, fm, body = content.split(/^---\s*$\n/, 3)
  [YAML.safe_load(fm || "") || {}, body.to_s]
end

def change_frontmatter(skill_md)
  data, body = parse_frontmatter(skill_md)
  if block_given?
    yield data
    File.write(skill_md, "---\n#{data.to_yaml.sub(/\A---\n/, "")}---\n#{body}")
  end
  data
end

def symlink(src_abs, dst, name)
  File.symlink(src_abs, dst)
  puts "linked #{name} -> #{src_abs}"
end

def fetch(url)
  out = IO.popen(["curl", "--fail", "--silent", "--show-error", "--location", url], &:read)
  abort "download failed: #{url}" unless $?.success?
  out
end

def git_ref(dir)
  ref = `git -C #{dir.shellescape} rev-parse HEAD 2>/dev/null`.strip
  ref.empty? ? nil : ref
end

def write_marker(dst, source, changes, git_ref: nil, gsubs: nil)
  marker = {"source" => source, "changes" => changes}
  marker["gsubs"] = gsubs if gsubs && !gsubs.empty?
  marker["git_ref"] = git_ref if git_ref
  File.write(File.join(dst, MARKER), marker.to_yaml)
end

def apply_gsubs(skill_md, gsubs)
  return if gsubs.nil? || gsubs.empty?
  content = File.read(skill_md)
  gsubs.each { |search, replace| content = content.gsub(search, replace) }
  File.write(skill_md, content)
end

def skill_name(dir)
  change_frontmatter(File.join(dir, "SKILL.md"))["name"] || File.basename(dir)
end

def check_dst!(dst)
  return unless File.exist?(dst)
  abort "conflict: #{dst} already exists, refusing to overwrite"
end

def copy_folder_with_changes(src_dir, dst, name, changes, gsubs: nil)
  FileUtils.cp_r(src_dir, dst)
  skill_md = File.join(dst, "SKILL.md")
  change_frontmatter(skill_md) { |fm| fm.merge!(changes) }
  apply_gsubs(skill_md, gsubs)
  write_marker(dst, src_dir, changes, git_ref: git_ref(src_dir), gsubs: gsubs)
  puts "copied #{name} from #{src_dir} (changes: #{changes.inspect})"
end

# writes SKILL.md to disk first, then (optionally) lets a block decide on
# additional frontmatter changes based on the downloaded content.
def install_url_with_changes(url, dst, name, changes: nil, gsubs: nil)
  FileUtils.mkdir_p(dst)
  skill_md = File.join(dst, "SKILL.md")
  File.write(skill_md, fetch(url))
  changes ||= yield(parse_frontmatter(skill_md).first, dst)
  change_frontmatter(skill_md) { |fm| fm.merge!(changes) } unless changes.empty?
  apply_gsubs(skill_md, gsubs)
  write_marker(dst, url, changes, gsubs: gsubs)
  puts "downloaded #{name} from #{url} (changes: #{changes.inspect})"
end

def install_from_folder(folder)
  src_abs = File.realpath(File.expand_path(folder))
  abort "not a directory: #{src_abs}" unless File.directory?(src_abs)

  skill_md = File.join(src_abs, "SKILL.md")
  abort "missing SKILL.md in #{src_abs}" unless File.file?(skill_md)

  name = skill_name(src_abs)
  dst = File.join(DEST, name)
  check_dst!(dst)

  if change_frontmatter(skill_md)["disable-model-invocation"] == true
    symlink(src_abs, dst, name)
    return
  end

  print "#{name} does not have `disable-model-invocation: true`\n[l]ink as-is, [c]opy with disable-model-invocation: false, [a]bort? "
  case $stdin.gets.strip.downcase
  when "l", "link"
    symlink(src_abs, dst, name)
  when "c", "copy"
    copy_folder_with_changes(src_abs, dst, name, {"disable-model-invocation" => true})
  else
    abort "aborted"
  end
end

def install_from_url(url)
  name = url.split("/")[-2] || raise # http://foo/bar/SKILL.md -> bar
  dst = File.join(DEST, name)
  check_dst!(dst)

  install_url_with_changes(url, dst, name) do |fm, dst_dir|
    if fm["disable-model-invocation"] == true
      {}
    else
      print "#{name} has model invocation enabled. [c]opy with invocation disabled, [k]eep as-is, [a]bort? "
      case $stdin.gets&.strip&.downcase
      when "c", "copy" then {"disable-model-invocation" => true}
      when "k", "keep" then {}
      else
        FileUtils.rm_rf(dst_dir)
        abort "aborted"
      end
    end
  end
end

def refresh
  Dir.children(DEST).sort.each do |name|
    dst = File.join(DEST, name)
    marker = File.join(dst, MARKER)
    next if File.symlink?(dst) || !File.file?(marker)

    info = YAML.safe_load(File.read(marker))
    src = info["source"] || raise("missing source")
    changes = info["changes"] || {}
    gsubs = info["gsubs"]

    if url?(src)
      FileUtils.rm_rf(dst)
      install_url_with_changes(src, dst, name, changes: changes, gsubs: gsubs)
    else
      unless File.directory?(src)
        warn "skipped #{name}: source #{src.inspect} is missing"
        next
      end
      FileUtils.rm_rf(dst)
      copy_folder_with_changes(src, dst, name, changes, gsubs: gsubs)
    end
  end
end

abort "destination dir does not exist: #{DEST}" unless File.directory?(DEST)

if ARGV.delete("--refresh")
  abort "unexpected arguments: #{ARGV.join(" ")}" unless ARGV.empty?
  refresh
else
  arg = ARGV.shift || abort("usage: claude-skill-install <folder-or-url> | --refresh")
  abort "unexpected arguments: #{ARGV.join(" ")}" unless ARGV.empty?
  if url?(arg)
    install_from_url(arg)
  else
    install_from_folder(arg)
  end
end
