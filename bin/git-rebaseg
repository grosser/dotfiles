#!/bin/bash
# Rebase onto <branch>, auto-resolving conflicts in generated files by taking
# the version from the branch being rebased (`git checkout --theirs`).
#
# Generated files are detected via `git check-attr` (linguist-generated /
# linguist-vendored), so all nested .gitattributes files are honored.
#
# With --claude, non-generated conflicts are resolved by a headless `claude`
# invocation before continuing the rebase.
#
# Usage: git-rebaseg [--claude] <upstream> [extra git-rebase args...]
#   git-rebaseg master
#   git-rebaseg --claude master
set -e

# capture --claude arg
use_claude=0
args=()
for arg in "$@"; do
  if [ "$arg" = "--claude" ]; then
    use_claude=1
  else
    args+=("$arg")
  fi
done
set -- "${args[@]}"

if [ $# -eq 0 ]; then
  echo "Usage: git-rebaseg [--claude] <upstream> [extra git-rebase args...]" >&2
  exit 1
fi

# Is the given path a generated/vendored file?
is_generated() {
  git check-attr linguist-generated linguist-vendored -- "$1" |
    grep -qE ': (set|true)$'
}

# Resolve any conflicting generated files with --theirs (the branch being rebased).
# Returns 0 only if there was at least one conflict and all were generated.
any_resolved_at_all=0
resolve_generated_conflicts() {
  local any_resolved=0 any_unresolved=0
  while IFS= read -r path; do
    [ -z "$path" ] && continue
    if is_generated "$path"; then
      echo "git-rebaseg: resolving generated conflict with --theirs: $path"
      git checkout --theirs -- "$path"
      git add -- "$path"
      any_resolved=1
      any_resolved_at_all=1
    else
      any_unresolved=1
    fi
  done < <(git diff --name-only --diff-filter=U)

  [ "$any_resolved" -eq 1 ] && [ "$any_unresolved" -eq 0 ]
}

# Render claude's stream-json output as readable text: assistant text as it
# streams, plus a one-line marker for each tool use.
stream_claude_output() {
  jq -j --unbuffered '
    if .type == "stream_event" and .event.type == "content_block_delta"
       and .event.delta.type == "text_delta" then .event.delta.text
    elif .type == "assistant" then
      (.message.content[]? | select(.type == "tool_use")
        | "\n[" + .name + "] "
          + (.input.file_path // .input.command // .input.path // "") + "\n")
    else empty end
  ' 2>/dev/null
}

# Ask a headless claude to resolve the remaining (non-generated) conflicts.
# Returns 0 only if no conflicting files remain afterwards.
resolve_conflicts_with_claude() {
  local remaining
  remaining=$(git diff --name-only --diff-filter=U)
  echo "git-rebaseg: asking claude to resolve conflict(s):" >&2
  echo "$remaining" | sed 's/^/  /' >&2

  claude -p "Resolve the current git rebase conflict. Edit the conflicting \
files to a correct merged result, remove all conflict markers, and \
'git add' each resolved file. Do NOT run 'git rebase --continue' or any \
other git rebase command." \
    --allow-dangerously-skip-permissions \
    --output-format stream-json --include-partial-messages --verbose |
    stream_claude_output

  # Success only if claude staged everything and left no unmerged paths.
  [ -z "$(git diff --name-only --diff-filter=U)" ]
}

# Start the rebase; do not exit on non-zero (conflicts are expected).
set +e
git rebase "$@"
status=$?

while [ $status -ne 0 ]; do
  if ! resolve_generated_conflicts; then
    if [ "$use_claude" -eq 1 ] && resolve_conflicts_with_claude; then
      : # conflict resolved by claude, fall through to --continue
    else
      echo "git-rebaseg: unable to resolve conflict." >&2
      exit $status
    fi
  fi

  git rebase --continue
  status=$?
done

if [ "$any_resolved_at_all" -eq 1 ]; then
  echo "git-rebaseg: done. Regenerate files (e.g. bundle exec rake generate)."
fi
